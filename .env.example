# =========================================================
# .env.example — Dimerco IEEPA Refund Calculator
# Document Reference: DMX-TRS-IEEPA-2026-001
#
# Usage:
#   cp .env.example .env
#   # Fill in all REPLACE_WITH_* values before starting
#   chmod 600 .env   (production)
#
# NEVER commit .env to version control.
# =========================================================

# ---------------------------------------------------------
# 基本設定
# ---------------------------------------------------------
ENVIRONMENT=development              # development | staging | production
DEBUG=true                           # dev: true | staging/prod: false
LOG_LEVEL=DEBUG                      # DEBUG | INFO | WARNING | ERROR
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=REPLACE_WITH_32_BYTE_RANDOM_HEX   # python -c "import secrets; print(secrets.token_hex(32))"
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------
# CORS 設定
# ---------------------------------------------------------
CORS_ORIGINS=http://localhost:5173   # staging: https://staging.ieepa.dimerco.local | prod: https://ieepa.dimerco.com
CORS_ALLOW_CREDENTIALS=true

# ---------------------------------------------------------
# JWT 設定
# ---------------------------------------------------------
JWT_SECRET_KEY=REPLACE_WITH_64_BYTE_RANDOM_HEX   # python -c "import secrets; print(secrets.token_hex(64))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------
# 資料庫 — PostgreSQL 15
# ---------------------------------------------------------
POSTGRES_HOST=db                     # dev/staging: db (Docker service) | prod: db.internal.dimerco.local
POSTGRES_PORT=5432
POSTGRES_DB=ieepa_refund_db
POSTGRES_USER=ieepa_app
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------------------------------------------------------
# Redis 7
# ---------------------------------------------------------
REDIS_HOST=redis                     # dev/staging: redis (Docker service) | prod: redis.internal.dimerco.local
REDIS_PORT=6379
REDIS_PASSWORD=                      # dev: 可留空 | prod: 必填強密碼
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CACHE_TTL_SECONDS=3600               # HTS 稅率快取 TTL（1 小時）

# ---------------------------------------------------------
# 本地檔案系統（取代 AWS S3）
# ---------------------------------------------------------
DATA_ROOT=/data
UPLOAD_DIR=${DATA_ROOT}/uploads
REPORTS_DIR=${DATA_ROOT}/reports
KEYS_DIR=${DATA_ROOT}/keys
FERNET_KEY_PATH=${KEYS_DIR}/app_secret.key
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png
DOWNLOAD_TOKEN_EXPIRE_MINUTES=15

# ---------------------------------------------------------
# OCR — 主引擎：Google Document AI
# ---------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google_service_account.json
GOOGLE_DOC_AI_PROJECT_ID=REPLACE_WITH_GCP_PROJECT_ID
GOOGLE_DOC_AI_LOCATION=us
GOOGLE_DOC_AI_PROCESSOR_ID=REPLACE_WITH_PROCESSOR_ID

# OCR — 備援：pytesseract（本地 Tesseract，取代 AWS Textract）
TESSERACT_CMD=/usr/bin/tesseract
OCR_FALLBACK_ENABLED=true
OCR_CONFIDENCE_THRESHOLD=0.80        # 低於此值標記為 review_required

# ---------------------------------------------------------
# Email（取代 AWS SES）
# ---------------------------------------------------------
SMTP_HOST=mailhog                    # dev: mailhog (Docker) | staging/prod: smtp.internal.dimerco.local
SMTP_PORT=1025                       # dev: 1025 (MailHog) | prod: 587 (STARTTLS)
SMTP_USERNAME=                       # prod: 填入正式帳號
SMTP_PASSWORD=                       # prod: 填入正式密碼
SMTP_USE_TLS=false                   # dev: false | prod: true
SMTP_FROM_ADDRESS=noreply@ieepa.dimerco.com
SMTP_FROM_NAME=Dimerco IEEPA Portal

# ---------------------------------------------------------
# PII 加密（Fernet AES-256-GCM，取代 AWS KMS）
# 金鑰由 init_keys.py 生成，儲存於 FERNET_KEY_PATH
# 生產環境務必以離線方式備份 data/keys/app_secret.key
# ---------------------------------------------------------

# ---------------------------------------------------------
# Rate Limiting（取代 AWS WAF）— slowapi (Layer 2)
# ---------------------------------------------------------
RATE_LIMIT_UPLOAD=10/hour
RATE_LIMIT_CALCULATE=10/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_GET=60/minute

# ---------------------------------------------------------
# CRM 整合
# ---------------------------------------------------------
ENABLE_CRM_SYNC=false                # dev/staging: false | prod: true
CRM_WEBHOOK_URL=                     # prod: 填入 CRM REST API endpoint
CRM_API_KEY=                         # prod: 填入 CRM API key

# ---------------------------------------------------------
# 功能開關
# ---------------------------------------------------------
ENABLE_BULK_UPLOAD=true

# ---------------------------------------------------------
# Celery Beat — 清理排程
# ---------------------------------------------------------
FILE_CLEANUP_TTL_HOURS=24            # uploads/ 目錄 24 小時後清除
REPORT_CLEANUP_TTL_DAYS=90           # reports/ 目錄 90 天後清除
CLEANUP_SCHEDULE_CRON=0 * * * *      # 每整點執行

# ---------------------------------------------------------
# 前端分析
# ---------------------------------------------------------
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
